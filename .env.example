# ===========================================
# Freqtrade Strategy Agent Configuration
# ===========================================
# Copy this file to .env and fill in your values.

# ---------- LLM Configuration ----------
# Provider: ollama (free/local), anthropic (paid), openai (paid)
LLM_PROVIDER=ollama
# Model name (must match your provider):
#   Ollama: qwen3.5:latest, llama3.1:8b, gemma4:latest
#   Anthropic: claude-sonnet-4-6
#   OpenAI: gpt-4o
LLM_MODEL=qwen3.5:latest
# Ollama server URL (only needed for Ollama provider)
OLLAMA_BASE_URL=http://localhost:11434
# API keys for paid providers (only needed if LLM_PROVIDER=anthropic/openai)
# ANTHROPIC_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# ---------- Data Source API Keys ----------
# Free sign-up: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# Free tier: https://min-api.cryptocompare.com/
CRYPTOCOMPARE_API_KEY=
# Free tier: https://newsapi.org/
NEWSAPI_KEY=
# Free tier (optional, 1K calls/month): https://santiment.net/
SANTIMENT_API_KEY=

# ---------- Exchange Configuration ----------
# Exchange for OHLCV data (uses public endpoints, no API key needed)
EXCHANGE_ID=binance
# Only needed for private endpoints (trading):
# EXCHANGE_API_KEY=
# EXCHANGE_API_SECRET=

# ---------- Autonomous Agent ----------
# Auto-start the agent when the server boots (true/false)
AUTOSTART_AUTONOMOUS=true

# ---------- Slack Integration ----------
SLACK_WEBHOOK_URL=

# ---------- Freqtrade Manager ----------
FREQTRADE_IMAGE=freqtradeorg/freqtrade:stable
LOG_LEVEL=INFO
MANAGER_PORT=8765

# ---------- Dashboard ----------
NEXT_PUBLIC_WS_URL=ws://localhost:8765
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------- Database ----------
DATABASE_PATH=/data/dashboard.db

# ---------- Ports ----------
BASE_PORT=7070